# Mo Conventionalcell
# Generates a 2 atom Mo_primitvecell with the multiplicity of 1:1:1 (x:y:z), and computes the band structure.

#################################################################
#Definition of occupation numbers 
##################################################################
occopt 7                        #Check this
tsmear 0.005
nband 20
#################################################################

#################################################################
#Defining geometry
##################################################################
  acell   5.9750546617E+00  5.9750546617E+00  5.9750546617E+00 Bohr
  rprim  1  0  0
         0  1  0
         0  0  1  

xred
0    0    0
0.5  0.5  0.5 

chkprim 0
nsym 1
#################################################################
#Defining atoms
##################################################################
 ntypat   1 
  znucl   42
  natom   2
  typat   1 1
  nstep   50                      
#################################################################
#Simulation parameters
##################################################################
ecut  30.0                       # Maximal kinetic energy cut-off, in Hartree
ixc 11                          # Perdew-Burke-Ernzerhof GGA functional [Perdew1996]

#################################################################
#Dataset 1
##################################################################
nshiftk 1                       # number of shifted grids
shiftk
0 0 0
ngkpt  8 8 8

prtden  1         # Print the density, for use by dataset 2
tolvrs  1.0d-10         # tolerance for potential residual

prtvol 2
istwfk *1
#iomode2 3
prteig 1
#prtwf  1
#autoparal 1
pseudos "/users/suryab/Project/pseudos/PSP/pseudo_dojo/Mo.psp8"
